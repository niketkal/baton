{
  "name": "@batonai/conformance",
  "version": "1.0.4",
  "license": "Apache-2.0",
  "description": "Baton public conformance suite (synthetic fixtures only).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "baton-conformance": "./dist/bin/baton-conformance.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "cases", "benchmark", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts src/bin/baton-conformance.ts --format esm --dts --clean --target node20",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@batonai/lint": "workspace:*",
    "@batonai/render": "workspace:*",
    "@batonai/schema": "workspace:*",
    "commander": "12.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niketkal/baton.git",
    "directory": "packages/conformance"
  },
  "homepage": "https://github.com/niketkal/baton#readme",
  "bugs": {
    "url": "https://github.com/niketkal/baton/issues"
  }
}
