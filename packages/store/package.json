{
  "name": "@batonai/store",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "description": "Baton repo-local state. Files canonical, SQLite cache.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@batonai/schema": "workspace:*",
    "better-sqlite3": "12.9.0",
    "remark-parse": "11.0.0",
    "remark-stringify": "11.0.0",
    "unified": "11.0.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.12"
  }
}
