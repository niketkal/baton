{
  "name": "@batonai/cli",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "description": "Baton command-line interface.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "baton": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "scripts", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean --target node20",
    "test": "vitest run",
    "test:performance": "vitest run --config vitest.performance.config.ts",
    "typecheck": "tsc --noEmit",
    "lint:logs": "node scripts/lint-logs.mjs"
  },
  "dependencies": {
    "@batonai/adapters": "workspace:*",
    "@batonai/compiler": "workspace:*",
    "@batonai/conformance": "workspace:*",
    "@batonai/integrations": "workspace:*",
    "@batonai/lint": "workspace:*",
    "@batonai/llm": "workspace:*",
    "@batonai/render": "workspace:*",
    "@batonai/schema": "workspace:*",
    "@batonai/store": "workspace:*",
    "clipboardy": "4.0.0",
    "commander": "12.1.0",
    "pino": "9.5.0",
    "smol-toml": "1.3.1"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "*",
    "openai": "*"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  }
}
