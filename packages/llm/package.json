{
  "name": "@batonai/llm",
  "version": "1.0.1",
  "license": "Apache-2.0",
  "description": "Baton BYOK LLM provider abstraction.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@batonai/schema": "workspace:*"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.32.1",
    "@anthropic-ai/tokenizer": "0.0.4",
    "js-tiktoken": "1.0.16",
    "openai": "4.77.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "*",
    "@anthropic-ai/tokenizer": "*",
    "js-tiktoken": "*",
    "openai": "*"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@anthropic-ai/tokenizer": {
      "optional": true
    },
    "js-tiktoken": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niketkal/baton.git",
    "directory": "packages/llm"
  },
  "homepage": "https://github.com/niketkal/baton#readme",
  "bugs": {
    "url": "https://github.com/niketkal/baton/issues"
  }
