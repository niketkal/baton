{
  "name": "@baton/schema",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "description": "Baton packet JSON Schema (CC0) and generated TypeScript types.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./migrate": {
      "types": "./dist/migrate.d.ts",
      "import": "./dist/migrate.js"
    },
    "./packet.schema.json": "./packet.schema.json"
  },
  "files": ["dist", "packet.schema.json", "README.md"],
  "scripts": {
    "codegen": "json2ts -i packet.schema.json -o src/types.ts --no-additionalProperties",
    "build": "tsup src/index.ts src/migrate.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1"
  },
  "devDependencies": {
    "json-schema-to-typescript": "15.0.3"
  }
}
